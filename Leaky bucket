#include <stdio.h>
#include <stdlib.h>

void leakybucket(int buckc,int lr,int np ,int packet[np])
{
	int bucket=0;
	printf("TIME\tIncoming\tBucket\tLeaked\tRemaining\n");
	for(int i=0;i<np;i++)
	{
		printf("%d\t %d",i+1,packet[i]);
		bucket=bucket+packet[i];
		if(bucket>buckc)
		{
			printf("Bucket overflowed and dropped %d",bucket-buckc);
		}
		else
		{
			printf("\t%d",bucket);
		}
		
		int leaked = bucket>=lr ?lr:bucket;
		printf("\t%d\t%d\n",leaked,bucket-leaked);
		bucket=bucket-leaked;
	}
	
	int time=np+1;
	while(bucket>0)
	{
		int leaked=(bucket>=lr)?lr:bucket;
		printf("%d\t%d\t%d\t%d\t%d\n",time,0,bucket,leaked,bucket-leaked);
		bucket=bucket-leaked;
		time++;
	}
}

void main()
{
	int buckc,lr,np;
	printf("Enter Bucket capacity\n");
	scanf("%d",&buckc);
	
	printf("Enter Leak Rate\n");
	scanf("%d",&lr);
	
	printf("Enter Number of packets\n");
	scanf("%d",&np);
	
	int packet[np];
	
	for(int i=0;i<np;i++)
	{
		printf("Enter incoming packet size\t");
		scanf("%d",&packet[i]);	
	}
	
	leakybucket(buckc,lr,np,packet);
}
